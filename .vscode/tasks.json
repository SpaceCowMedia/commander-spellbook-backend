{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "manage.py: run command…",
            "detail": "Prompt for any manage.py subcommand and arguments",
            "type": "shell",
            "command": "uv run manage.py ${input:managePyCommand}",
            "group": "none",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}/backend",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}${/}common",
                },
            }
        },
        {
            "label": "manage.py: check",
            "detail": "python manage.py check",
            "type": "shell",
            "command": "uv run manage.py check",
            "group": "none",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}/backend",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}${/}common",
                },
            }
        },
        {
            "label": "manage.py: makemigrations",
            "detail": "python manage.py makemigrations",
            "type": "shell",
            "command": "uv run manage.py makemigrations",
            "group": "none",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}/backend",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}${/}common",
                },
            }
        },
        {
            "label": "manage.py: showmigrations",
            "detail": "python manage.py showmigrations",
            "type": "shell",
            "command": "uv run manage.py showmigrations",
            "group": "none",
            "problemMatcher": [],
            "options": {
                "cwd": "${workspaceFolder}/backend",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}${/}common",
                },
            }
        },
        {
            "label": "Apply migrations",
            "type": "shell",
            "command": "uv run manage.py migrate",
            "group": "none",
            "options": {
                "cwd": "${workspaceFolder}/backend",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}${/}common",
                },
            }
        },
        {
            "label": "Seed Website Properties",
            "type": "shell",
            "command": "uv run manage.py seed_website_properties",
            "group": "none",
            "dependsOn": [
                "Apply migrations"
            ],
            "options": {
                "cwd": "${workspaceFolder}/backend",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}${/}common",
                },
            }
        },
        {
            "label": "Create temporary directories",
            "type": "shell",
            "args": [],
            "group": "none",
            "linux": {
                "command": "mkdir -p ${workspaceFolder}/backend/temp/profiles"
            },
            "windows": {
                "command": "if not exist ${workspaceFolder}\\backend\\temp\\profiles mkdir ${workspaceFolder}\\backend\\temp\\profiles",
                "options": {
                    "shell": {
                        "executable": "cmd",
                        "args": [
                            "/c"
                        ]
                    }
                }
            }
        },
        {
            "label": "Upkeep",
            "type": "shell",
            "command": "uv run manage.py upkeep",
            "group": "none",
            "dependsOn": [
                "Apply migrations"
            ],
            "options": {
                "cwd": "${workspaceFolder}/backend",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}${/}common",
                },
            }
        },
        {
            "label": "Prelaunch",
            "group": "none",
            "dependsOn": [
                "Apply migrations",
                "Upkeep",
                "Seed Website Properties",
            ],
            "options": {
                "env": {
                    "PYTHONPATH": "${workspaceFolder}${/}common",
                },
            }
        },
        {
            "label": "Apply migrations with production settings",
            "type": "shell",
            "command": "set -a; . \"$ENV_FILE\"; uv run manage.py migrate --settings=backend.production_settings",
            "group": "none",
            "options": {
                "cwd": "${workspaceFolder}/backend",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}${/}common",
                    "ENV_FILE": "${workspaceFolder}/backend/secrets.env",
                },
            },
        },
        {
            "label": "Seed Website Properties with production settings",
            "type": "shell",
            "command": "set -a; . \"$ENV_FILE\"; uv run manage.py seed_website_properties --settings=backend.production_settings",
            "group": "none",
            "options": {
                "cwd": "${workspaceFolder}/backend",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}${/}common",
                    "ENV_FILE": "${workspaceFolder}/backend/secrets.env",
                },
            }
        },
        {
            "label": "Upkeep with production settings",
            "type": "shell",
            "command": "set -a; . \"$ENV_FILE\"; uv run manage.py upkeep --settings=backend.production_settings",
            "group": "none",
            "dependsOn": [
                "Apply migrations"
            ],
            "options": {
                "cwd": "${workspaceFolder}/backend",
                "env": {
                    "PYTHONPATH": "${workspaceFolder}${/}common",
                    "ENV_FILE": "${workspaceFolder}/backend/secrets.env",
                },
            }
        },
        {
            "label": "Prelaunch with production settings",
            "group": "none",
            "dependsOn": [
                "Apply migrations with production settings",
                "Upkeep with production settings",
                "Seed Website Properties with production settings",
            ],
        }
    ],
    "inputs": [
        {
            "id": "managePyCommand",
            "type": "promptString",
            "description": "manage.py subcommand and arguments (e.g. 'makemigrations spellbook')"
        }
    ]
}
